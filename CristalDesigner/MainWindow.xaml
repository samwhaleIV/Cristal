<Window x:Class="CristalDesigner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CristalDesigner"
        mc:Ignorable="d"
        Title="Cristal Designer" Height="506" Width="826" WindowStyle="ToolWindow">
    <Grid x:Name="OuterGrid" Background="#FF8C8C8C">
        <Button x:Name="GenerationButton" Content="Generate New Texture" VerticalAlignment="Top" Margin="10,75,0,0" Height="28" Click="Button_Click" Width="300" HorizontalAlignment="Left" RenderTransformOrigin="0.509,-0.907"/>
        <Image x:Name="TextureGenerationTarget" Margin="320,10,10,10" HorizontalAlignment="Left"/>
        <Grid HorizontalAlignment="Left" VerticalAlignment="Top" Width="300" Height="60" Margin="10,10,0,0" Background="White">
            <TextBox x:Name="ScaleInput" TextWrapping="Wrap" Text="10.0" VerticalContentAlignment="Center" Padding="10,0,0,0" Margin="40,0,42,0" VerticalAlignment="Center" Height="42"/>
            <Label Content="Scale:" HorizontalAlignment="Left" VerticalContentAlignment="Center" HorizontalContentAlignment="Center" Width="38" Margin="2,0,0,0"/>
            <Button x:Name="ScaleMinus" Content="-" HorizontalAlignment="Right" VerticalAlignment="Center" Height="19" Width="34" HorizontalContentAlignment="Center" VerticalContentAlignment="Center" Click="ScaleMinus_Click" Margin="0,0,4,23"/>
            <Button x:Name="ScalePlus" Content="+" HorizontalAlignment="Right" VerticalAlignment="Center" Height="19" Width="34" Click="ScalePlus_Click" Margin="0,23,4,0"/>
        </Grid>
    </Grid>
</Window>
