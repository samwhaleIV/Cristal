<?xml version="1.0" encoding="utf-8"?>
<cristallab:WorkspacePage
    xmlns:cristallab="using:CristalLab"
    x:Class="CristalLab.Pages.NoiseGenerationTest"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CristalLab.Pages"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    NavigationCacheMode="Required"
    Loaded="WorkspacePage_Loaded">

    <Grid Margin="12" CornerRadius="4">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>
        <StackPanel
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            Padding="24"
            CornerRadius="4"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            Margin="0,0,12,0"
            Grid.Column="0"
            Grid.ColumnSpan="1"
            Spacing="16"
            VerticalAlignment="Top"
            HorizontalAlignment="Left"
            Width="360">

            <TextBlock
                Text="Noise Generation"
                Style="{ThemeResource TitleTextBlockStyle}"
            />
            <TextBlock
                Text="Generate a texture using the OpenSimplex2S procedural noise algorithm."
                Style="{ThemeResource BodyTextBlockStyle}"
            />

            <Slider
                x:Name="ScaleSlider"
                Header="Noise Scale"
                Minimum="0.1"
                Value="10.0"
                SmallChange="0.1"
                StepFrequency="0.1"
                Maximum="100.0"
                ValueChanged="ScaleSlider_ValueChanged"
                />

            <TextBlock
                Text="Island mode activates post processing that forms celluloid patterns by resampling linear gradients."
                Style="{ThemeResource BodyTextBlockStyle}"
            />
            <Grid >

                <Grid.RowDefinitions>
                    <RowDefinition></RowDefinition>
                    <RowDefinition></RowDefinition>
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition/>
                    <ColumnDefinition/>
                </Grid.ColumnDefinitions>

                <ToggleSwitch
                    x:Name="IslandToggleSwitch"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Grid.Row="0"
                    OffContent="Island Mode"
                    OnContent="Island Mode"
                    IsOn="False"
                    HorizontalAlignment="Center"
                    Toggled="IslandToggleSwitch_Toggled"
                    />

                <Slider
                    x:Name="IslandPivotSlider"
                    Header="Pivot"
                    Grid.Column="0"
                    Grid.Row="1"
                    IsEnabled="{x:Bind IslandToggleSwitch.IsOn, Mode=OneWay}"
                    Minimum="0.05"
                    Value="0.5"
                    SmallChange="0.05"
                    StepFrequency="0.05"
                    Maximum="0.95"
                    HorizontalAlignment="Stretch"
                    Margin="0,0,8,0"
                    ValueChanged="IslandPivotSlider_ValueChanged"
                    />

                <Slider
                    x:Name="IslandRolloffSlider"
                    Header="Softness"
                    Grid.Column="1"
                    Grid.Row="1"
                    IsEnabled="{x:Bind IslandToggleSwitch.IsOn, Mode=OneWay}"
                    Minimum="0.01"
                    Value="0.05"
                    SmallChange="0.01"
                    StepFrequency="0.01"
                    Maximum="0.5"
                    HorizontalAlignment="Stretch"
                    Margin="8,0,0,0"
                    ValueChanged="IslandRolloffSlider_ValueChanged"
                    />
            </Grid>

        </StackPanel>
        <Grid
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            Grid.Column="1"
            Grid.ColumnSpan="1"
            BorderThickness="1"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            CornerRadius="4"
            Padding="12"
            Margin="0">
            <Image
                x:Name="BitmapContainer"
                Stretch="Uniform"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"/>
        </Grid>
    </Grid>
</cristallab:WorkspacePage>
