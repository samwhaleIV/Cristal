<?xml version="1.0" encoding="utf-8"?>
<NavigationView
    x:Class="CristalLab.WorkspaceRoot"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CristalLab"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    x:Name="Navigation"
    IsSettingsVisible="False"
    ItemInvoked="Nav_ItemInvoked"
    Loaded="Nav_Loaded"
    IsBackButtonVisible="Collapsed"
    Padding="0"
    Margin="0"
    Background="{ThemeResource LayerFillColorDefault}"
    PaneDisplayMode="Top">
    <NavigationView.Transitions>
        <TransitionCollection />
    </NavigationView.Transitions>

    <NavigationView.Resources>
        <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="{ThemeResource LayerFillColorDefault}" />
        <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="{ThemeResource LayerFillColorDefault}" />
        <SolidColorBrush x:Key="NavigationViewTopPaneBackground" Color="{ThemeResource LayerFillColorDefault}" />
        <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent" />
    </NavigationView.Resources>

    <NavigationView.MenuItems>
        <NavigationViewItem x:Uid="HomePageNavItem" Content="Home" Tag="home">
            <NavigationViewItem.Icon>
                <FontIcon Glyph="&#xEC26;"/>
            </NavigationViewItem.Icon>
        </NavigationViewItem>

        <NavigationViewItemSeparator/>
        <NavigationViewItemHeader Content="Debug"/>

        <NavigationViewItem x:Uid="TestPageNavItem" Content="Test Page" Tag="test">
            <NavigationViewItem.Icon>
                <FontIcon Glyph="&#xEBE8;"/>
            </NavigationViewItem.Icon>
            <NavigationViewItem.Transitions>
                <TransitionCollection />
            </NavigationViewItem.Transitions>
        </NavigationViewItem>

        <NavigationViewItem x:Uid="NoiseGenerationTestNavItem" Content="Noise Generation Test" Tag="noise">
            <NavigationViewItem.Icon>
                <FontIcon Glyph="&#xF61F;"/>
            </NavigationViewItem.Icon>
            <NavigationViewItem.Transitions>
                <TransitionCollection />
            </NavigationViewItem.Transitions>
        </NavigationViewItem>
    </NavigationView.MenuItems>

    <local:WorkspaceSession x:Name="ContentFrame">
        <local:WorkspaceSession.Transitions>
            <TransitionCollection />
        </local:WorkspaceSession.Transitions>
        <local:WorkspaceSession.ContentTransitions>
            <TransitionCollection />
        </local:WorkspaceSession.ContentTransitions>
    </local:WorkspaceSession>
</NavigationView>
